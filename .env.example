# Environment Variables Template
# Copy to .env and fill in values

# Ollama Cloud (for chat completions - llama3.2)
OLLAMA_CLOUD_BASE_URL=https://api.ollama.com/v1
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_CLOUD_MODEL=llama3.2

# HuggingFace local embeddings (sentence-transformers, runs on-device)
HF_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B
HF_TOKEN=your_huggingface_token_here

# Embedding settings
EMBEDDING_DIMENSION=1024

# Storage
LANCEDB_PATH=/data/lancedb
DOCUMENTS_PATH=/data/documents

# Google OAuth 2.0
# Authorized redirect URI: https://<your-domain>/auth/callback/google
# Authorized JS origin:    https://<your-domain>
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT (path to keys generated by scripts/generate_jwt_keys.sh)
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public_key.pem

# Frontend
FRONTEND_ORIGIN=http://localhost:5333

# Cookie security — False for local HTTP dev, True for production HTTPS
COOKIE_SECURE=false

# File ingestion
ALLOWED_FOLDER_ROOTS=/data/documents

# Phase 2 features (set to true to enable LLM-based contextual prefix generation per chunk)
ENABLE_CONTEXTUAL_PREFIX=false

# Multimodal (image extraction from PDFs)
VISION_MODEL=gpt-4o-mini
VISION_ENABLED=true
VISION_MAX_PAGES=50
VISION_IMAGE_DPI=72

# Google Drive Push Notifications (webhook must be a public HTTPS URL)
# Leave empty to disable Drive change-detection webhooks
DRIVE_WEBHOOK_URL=https://your-domain.com/api/v1/drive/webhook

# Fine-tuning (OpenAI fine-tuning API)
OPENAI_API_KEY=sk-...

# Logging
RUST_LOG=info
# Hourly rotating JSON logs written to this directory (excluded from git)
LOG_DIR=./logs
# Sentry error tracking — leave blank to disable
SENTRY_DSN=

# Frontend (Vite)
VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=ws://localhost:8333/ws
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
