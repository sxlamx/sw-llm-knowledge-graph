# Development environment — copy to .env and fill in values
# cp deployment-dev/env/.env.example deployment-dev/env/.env

# Ollama Cloud (LLM completions)
OLLAMA_CLOUD_BASE_URL=https://api.ollama.com/v1
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_CLOUD_MODEL=gemma3:12b

# Embeddings (local Ollama on host machine)
OLLAMA_EMBED_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBED_MODEL=qwen3-embedding
OLLAMA_EMBED_DIMENSIONS=1024
EMBEDDING_DIMENSION=1024

# Storage
LANCEDB_PATH=/data/lancedb
DOCUMENTS_PATH=/data/documents
ALLOWED_FOLDER_ROOTS=/data/documents

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT (keys generated by scripts/generate_jwt_keys.sh)
JWT_PRIVATE_KEY_PATH=/app/secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=/app/secrets/jwt_public_key.pem
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_EXPIRY_DAYS=30

# Frontend
FRONTEND_ORIGIN=http://localhost:5342
COOKIE_SECURE=false

# Phase 2+ features
ENABLE_CONTEXTUAL_PREFIX=false

# Multimodal (PDF image extraction)
VISION_MODEL=gpt-4o-mini
VISION_ENABLED=true
VISION_MAX_PAGES=50
VISION_IMAGE_DPI=72

# OpenAI (fine-tuning)
OPENAI_API_KEY=

# Google Drive webhooks — leave empty to disable
DRIVE_WEBHOOK_URL=

# Logging
RUST_LOG=debug
LOG_DIR=./logs
SENTRY_DSN=
