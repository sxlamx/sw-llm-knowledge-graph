# Environment Variables Template
# Copy to .env and fill in values

# Ollama Cloud (for chat completions - llama3.2)
OLLAMA_CLOUD_BASE_URL=https://api.ollama.com/v1
OLLAMA_CLOUD_API_KEY=your_ollama_cloud_api_key_here
OLLAMA_CLOUD_MODEL=llama3.2

# Local Ollama (for embeddings - qwen3-embedding)
# Ollama must be running on host machine with GPU support
OLLAMA_EMBED_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=qwen3-embedding
OLLAMA_EMBED_DIMENSIONS=1536

# Embedding settings
EMBEDDING_DIMENSION=1536

# Storage
LANCEDB_PATH=/data/lancedb
DOCUMENTS_PATH=/data/documents

# Google OAuth 2.0
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# JWT (path to keys generated by scripts/generate_jwt_keys.sh)
JWT_PRIVATE_KEY_PATH=./secrets/jwt_private_key.pem
JWT_PUBLIC_KEY_PATH=./secrets/jwt_public_key.pem

# Frontend
FRONTEND_ORIGIN=http://localhost:3000

# File ingestion
ALLOWED_FOLDER_ROOTS=/data/documents

# Development
RUST_LOG=info
